{
  "name": "@hearth/domain",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./ids": "./src/ids.ts",
    "./errors": "./src/errors.ts",
    "./policy": "./src/policy/index.ts",
    "./policy/*": "./src/policy/*.ts",
    "./visibility": "./src/visibility/index.ts",
    "./visibility/*": "./src/visibility/*.ts",
    "./parts": "./src/parts/index.ts",
    "./parts/*": "./src/parts/*.ts",
    "./library": "./src/library/index.ts",
    "./library/*": "./src/library/*.ts"
  },
  "imports": {
    "#*": "./src/*"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@hearth/tsconfig": "workspace:*",
    "@total-typescript/ts-reset": "^0.6.1",
    "@types/node": "^22.9.0",
    "@vitest/coverage-v8": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
