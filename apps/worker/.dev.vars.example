# Copy to .dev.vars (gitignored) and fill in real values for local development.
# See ../../../docs/stack-claude.md "Deployment bootstrap" for canonical shape.

GOOGLE_OAUTH_CLIENT_ID="paste-from-google-cloud-console"
GOOGLE_OAUTH_CLIENT_SECRET="paste-from-google-cloud-console"

BETTER_AUTH_SECRET="generate-via-openssl-rand-base64-32"
# Local overrides — in prod these come from wrangler.jsonc [vars]
BETTER_AUTH_URL="http://localhost:8787"
BETTER_AUTH_TRUSTED_ORIGINS="http://localhost:5173,http://localhost:8787"

KILLSWITCH_TOKEN="generate-via-openssl-rand-hex-32"
HEARTH_BOOTSTRAP_OPERATOR_EMAIL="your-google-signin-email@example.com"

# R2 S3-compatibility credentials. Mint via the Cloudflare dashboard:
# R2 → Manage API Tokens → Create User API Token, scoped Object Read/Write
# on hearth-storage. R2_ACCOUNT_ID is your Cloudflare account id.
# R2_PUBLIC_ORIGIN is the bucket's public dev URL (`https://pub-…r2.dev`)
# or your custom domain bound to the bucket.
R2_ACCOUNT_ID="paste-from-cloudflare-dashboard"
R2_ACCESS_KEY_ID="paste-from-cloudflare-dashboard"
R2_SECRET_ACCESS_KEY="paste-from-cloudflare-dashboard"
R2_PUBLIC_ORIGIN="https://pub-xxxxx.r2.dev"

# Optional — uncomment when you have real values. Empty strings fail URL validation.
# SENTRY_DSN="https://...@sentry.io/..."
# DISCORD_WEBHOOK_URL="https://discord.com/api/webhooks/..."
